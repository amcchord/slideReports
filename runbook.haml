!!!
%html{lang: "en"}
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0"}
    %title Disaster Recovery Runbook
    %link{href: "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel: "stylesheet"}
    %link{href: "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css", rel: "stylesheet"}
    %link{href: "https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap", rel: "stylesheet"}
    %link{href: "https://raw.githubusercontent.com/amcchord/slideReports/main/runbook-styles.css", rel: "stylesheet"}

  %body
    .container-fluid
      / Header
      .row
        .col-12
          .text-center.py-4.bg-primary
            %h1
              %i.fas.fa-shield-alt.me-2
              Disaster Recovery Runbook
            %p.mb-0 Critical System Recovery Procedures

      / Executive Summary
      .row.mt-4
        .col-12
          .section-header
            %h2
              %i.fas.fa-clipboard-list.me-2
              Executive Summary
          .card
            .card-body
              .llm-placeholder
                Brief overview of the disaster recovery scenario and affected systems
              .row.mt-3
                .col-md-6
                  %strong Incident Type:
                  .llm-placeholder Type of disaster (hardware failure, cyber attack, natural disaster, etc.)
                .col-md-6
                  %strong Estimated Recovery Time:
                  .llm-placeholder Expected total recovery duration
              .row.mt-3
                .col-md-6
                  %strong Business Impact:
                  .llm-placeholder Critical/High/Medium/Low - Description of business impact
                .col-md-6
                  %strong Last Updated:
                  .llm-placeholder Date and time of last runbook update

      / Emergency Contacts
      .row.mt-4.emergency-contacts-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-phone.me-2
              Emergency Contacts
          .row
            .col-md-6
              .contact-card
                %h5
                  %i.fas.fa-user-tie.me-2
                  Incident Commander
                .llm-placeholder Primary decision maker name
                %strong Phone:
                %span.llm-placeholder Primary phone number
                %br
                %strong Alt Phone:
                %span.llm-placeholder Secondary phone number
                %br
                %strong Email:
                %span.llm-placeholder Email address
            .col-md-6
              .contact-card
                %h5
                  %i.fas.fa-tools.me-2
                  Technical Lead
                .llm-placeholder Technical lead name
                %strong Phone:
                %span.llm-placeholder Primary phone number
                %br
                %strong Alt Phone:
                %span.llm-placeholder Secondary phone number
                %br
                %strong Email:
                %span.llm-placeholder Email address
          .row
            .col-md-6
              .contact-card
                %h5
                  %i.fas.fa-network-wired.me-2
                  Network Administrator
                .llm-placeholder Network admin name
                %strong Phone:
                %span.llm-placeholder Primary phone number
                %br
                %strong Email:
                %span.llm-placeholder Email address
            .col-md-6
              .contact-card
                %h5
                  %i.fas.fa-building.me-2
                  Management/Stakeholders
                .llm-placeholder Management contact name
                %strong Phone:
                %span.llm-placeholder Phone number
                %br
                %strong Email:
                %span.llm-placeholder Email address

      / Server Inventory
      .row.mt-4.server-inventory-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-server.me-2
              Server Inventory & Configuration
          
          / Server 1
          .server-card
            .server-header
              %h4
                %i.fas.fa-desktop.me-2
                Primary Server
              %span.badge.bg-danger CRITICAL
            .card-body
              .row
                .col-md-6
                  %strong Server Name:
                  .llm-placeholder Primary server hostname
                  %strong IP Address:
                  .llm-placeholder Primary server IP address
                  %strong Role/Function:
                  .llm-placeholder Description of server role and critical services
                .col-md-6
                  %strong Operating System:
                  .llm-placeholder OS type and version
                  %strong Hardware Specs:
                  .llm-placeholder CPU, RAM, Storage specifications
                  %strong Location:
                  .llm-placeholder Physical/Cloud location
              .mt-3
                %strong Critical Services:
                .llm-placeholder List of critical services running on this server
              .mt-3
                %strong Dependencies:
                .llm-placeholder Other systems/services this server depends on

          / Server 2
          .server-card
            .server-header
              %h4
                %i.fas.fa-desktop.me-2
                Secondary Server
              %span.badge.bg-warning HIGH
            .card-body
              .row
                .col-md-6
                  %strong Server Name:
                  .llm-placeholder Secondary server hostname
                  %strong IP Address:
                  .llm-placeholder Secondary server IP address
                  %strong Role/Function:
                  .llm-placeholder Description of server role and services
                .col-md-6
                  %strong Operating System:
                  .llm-placeholder OS type and version
                  %strong Hardware Specs:
                  .llm-placeholder CPU, RAM, Storage specifications
                  %strong Location:
                  .llm-placeholder Physical/Cloud location
              .mt-3
                %strong Critical Services:
                .llm-placeholder List of services running on this server
              .mt-3
                %strong Dependencies:
                .llm-placeholder Other systems/services this server depends on

          / Additional Servers Template
          .server-card
            .server-header
              %h4
                %i.fas.fa-desktop.me-2
                Additional Server(s)
              %span.badge.bg-info MEDIUM
            .card-body
              .llm-placeholder
                Repeat server configuration details for any additional servers in the environment

      / Network Configuration
      .row.mt-4.network-config-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-network-wired.me-2
              Network Configuration
          .card
            .card-body
              .row
                .col-md-6
                  %h5 Network Details
                  %strong Primary Network:
                  .llm-placeholder Primary network range (e.g., 192.168.1.0/24)
                  %strong Gateway:
                  .llm-placeholder Default gateway IP address
                  %strong DNS Servers:
                  .llm-placeholder Primary and secondary DNS server IPs
                  %strong DHCP Range:
                  .llm-placeholder DHCP range if applicable
                .col-md-6
                  %h5 External Connectivity
                  %strong ISP/Provider:
                  .llm-placeholder Internet service provider name
                  %strong External IP:
                  .llm-placeholder Public IP address
                  %strong Firewall/Router:
                  .llm-placeholder Firewall device IP and model
                  %strong VPN Configuration:
                  .llm-placeholder VPN settings if applicable
              .mt-4
                %h5 Network Diagram
                .network-diagram
                  .llm-placeholder
                    ASCII network diagram or description of network topology showing server connections, switches, routers, and internet connectivity

      / Recovery Priority & Sequence
      .row.mt-4.recovery-priority-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-sort-numeric-up.me-2
              Recovery Priority & Startup Sequence
          .card
            .card-body
              .alert.alert-info
                %i.fas.fa-info-circle.me-2
                %strong Important:
                Follow this sequence to ensure proper system dependencies are met during recovery.
              
              .timeline-item.priority-high
                %h5
                  %span.step-number 1
                  Infrastructure & Network
                .llm-placeholder
                  First priority: Restore network infrastructure, firewalls, switches, and basic connectivity
                %strong Estimated Time:
                %span.llm-placeholder Time estimate

              .timeline-item.priority-high
                %h5
                  %span.step-number 2
                  Critical Database/Storage
                .llm-placeholder
                  Second priority: Restore database servers and shared storage systems
                %strong Estimated Time:
                %span.llm-placeholder Time estimate

              .timeline-item.priority-medium
                %h5
                  %span.step-number 3
                  Primary Application Servers
                .llm-placeholder
                  Third priority: Restore main application servers that depend on database/storage
                %strong Estimated Time:
                %span.llm-placeholder Time estimate

              .timeline-item.priority-medium
                %h5
                  %span.step-number 4
                  Secondary Services
                .llm-placeholder
                  Fourth priority: Restore supporting services like web servers, load balancers, monitoring
                %strong Estimated Time:
                %span.llm-placeholder Time estimate

              .timeline-item.priority-low
                %h5
                  %span.step-number 5
                  Additional Services
                .llm-placeholder
                  Final priority: Restore non-critical services and perform full system validation
                %strong Estimated Time:
                %span.llm-placeholder Time estimate

              .mt-4
                %strong Total Estimated Recovery Time:
                .llm-placeholder Sum of all recovery steps

      / Detailed Recovery Steps
      .row.mt-4.page-break.detailed-recovery-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-list-ol.me-2
              Detailed Recovery Procedures
          
          .accordion#recoveryAccordion
            / Step 1
            .accordion-item
              %h2.accordion-header
                %button.accordion-button{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#step1"}
                  %i.fas.fa-network-wired.me-2
                  Step 1: Network Infrastructure Recovery
              #step1.accordion-collapse.collapse.show
                .accordion-body
                  .llm-placeholder
                    |Detailed step-by-step instructions for restoring network infrastructure:
                    |1. Check physical connections
                    |2. Power on network equipment in correct order
                    |3. Verify firewall configuration
                    |4. Test internet connectivity
                    |5. Validate internal network communication
                  .mt-3
                    %strong Verification Steps:
                    .llm-placeholder Commands or tests to verify network is functioning properly

            / Step 2
            .accordion-item
              %h2.accordion-header
                %button.accordion-button.collapsed{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#step2"}
                  %i.fas.fa-database.me-2
                  Step 2: Database/Storage Recovery
              #step2.accordion-collapse.collapse
                .accordion-body
                  .llm-placeholder
                    |Detailed instructions for database and storage recovery:
                    |1. Mount storage volumes
                    |2. Check filesystem integrity
                    |3. Start database services
                    |4. Verify database connectivity
                    |5. Test data integrity
                  .mt-3
                    %strong Critical Files/Directories:
                    .llm-placeholder List of critical file paths and directories to verify

            / Step 3
            .accordion-item
              %h2.accordion-header
                %button.accordion-button.collapsed{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#step3"}
                  %i.fas.fa-server.me-2
                  Step 3: Application Server Recovery
              #step3.accordion-collapse.collapse
                .accordion-body
                  .llm-placeholder
                    |Detailed instructions for application server recovery:
                    |1. Start servers in dependency order
                    |2. Verify application configurations
                    |3. Test application connectivity
                    |4. Check service status
                    |5. Validate application functionality
                  .mt-3
                    %strong Service Commands:
                    .llm-placeholder Specific commands to start/stop/status check services

            / Additional Steps
            .accordion-item
              %h2.accordion-header
                %button.accordion-button.collapsed{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#stepAdditional"}
                  %i.fas.fa-cogs.me-2
                  Additional Recovery Steps
              #stepAdditional.accordion-collapse.collapse
                .accordion-body
                  .llm-placeholder
                    Additional recovery procedures specific to your environment

      / Verification & Testing
      .row.mt-4.verification-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-check-circle.me-2
              System Verification & Testing
          .card
            .card-body
              .row
                .col-md-6
                  %h5 Connectivity Tests
                  .llm-placeholder
                    |Network connectivity tests to perform:
                    |- Ping tests to critical servers
                    |- Port connectivity tests
                    |- DNS resolution tests
                    |- External connectivity validation
                .col-md-6
                  %h5 Application Tests
                  .llm-placeholder
                    |Application functionality tests:
                    |- User login tests
                    |- Database queries
                    |- File access tests
                    |- Performance benchmarks
              .mt-4
                %h5 Monitoring & Alerts
                .llm-placeholder
                  Steps to re-enable monitoring systems and verify alert functionality

      / Rollback Procedures
      .row.mt-4.rollback-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-undo.me-2
              Rollback Procedures
          .card
            .card-body
              .alert.alert-warning
                %i.fas.fa-exclamation-triangle.me-2
                %strong Warning:
                Use these procedures if recovery attempts fail or cause additional problems.
              .llm-placeholder
                |Step-by-step rollback procedures:
                |1. Document current state
                |2. Stop problematic services
                |3. Restore from backup points
                |4. Verify rollback success
                |5. Plan alternative recovery approach

      / Post-Recovery Tasks
      .row.mt-4.post-recovery-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-tasks.me-2
              Post-Recovery Tasks
          .card
            .card-body
              .row
                .col-md-6
                  %h5 Immediate Tasks
                  .llm-placeholder
                    |Tasks to complete immediately after recovery:
                    |- Notify stakeholders of recovery status
                    |- Update monitoring systems
                    |- Verify backup processes
                    |- Document any issues encountered
                .col-md-6
                  %h5 Follow-up Tasks
                  .llm-placeholder
                    |Tasks to complete within 24-48 hours:
                    |- Conduct post-mortem review
                    |- Update disaster recovery procedures
                    |- Test backup systems
                    |- Schedule security scans

      / Documentation & Notes
      .row.mt-4.mb-4.documentation-section
        .col-12
          .section-header
            %h2
              %i.fas.fa-sticky-note.me-2
              Recovery Notes & Documentation
          .card
            .card-body
              %h5 Recovery Log
              .llm-placeholder
                |Space for documenting the actual recovery process:
                |- Start time
                |- Steps completed
                |- Issues encountered
                |- Deviations from plan
                |- End time
                |- Lessons learned
              
              %h5.mt-4 Additional Notes
              .llm-placeholder
                Space for additional notes, observations, and recommendations for future improvements

      / Footer
      .row
        .col-12
          .text-center.text-muted.py-3.border-top
            %small
              This disaster recovery runbook should be reviewed and updated regularly.
              %br
              Last Updated:
              %span.llm-placeholder Date/Time
              |
              Version:
              %span.llm-placeholder Version Number

    %script{src: "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"} 