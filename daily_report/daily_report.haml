    / JavaScript
    :javascript
      // Toggle collapsible sections
      function toggleSection(sectionId) {
          const content = document.getElementById(sectionId + '-content');
          const arrow = document.getElementById(sectionId + '-arrow');
          
          if (content.classList.contains('expanded')) {
              content.classList.remove('expanded');
              arrow.style.transform = 'rotate(0deg)';
          } else {
              content.classList.add('expanded');
              arrow.style.transform = 'rotate(90deg)';
          }
      }

      // Screenshot modal functions
      function openScreenshot(src) {
          document.getElementById('modalImage').src = src;
          document.getElementById('screenshotModal').classList.remove('hidden');
      }

      function closeScreenshot() {
          document.getElementById('screenshotModal').classList.add('hidden');
      }

      // Close modal on escape key
      document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
              closeScreenshot();
          }
      });

      // Chart.js configurations
      window.onload = function() {
          // Overall Success Rate Chart (Compact)
          const overallCtx = document.getElementById('overallSuccessChart').getContext('2d');
          new Chart(overallCtx, {
              type: 'doughnut',
              data: {
                  labels: ['Successful', 'Failed'],
                  datasets: [{
                      data: [
                          // 🤖 LLM: Replace these values with actual snapshot statistics
                          parseInt('{{TOTAL_SUCCESSFUL_SNAPSHOTS}}') || 85,
                          parseInt('{{TOTAL_FAILED_SNAPSHOTS}}') || 5
                      ],
                      backgroundColor: ['#10b981', '#ef4444'],
                      borderWidth: 2,
                      borderColor: '#ffffff'
                  }]
              },
              options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                      legend: {
                          position: 'bottom',
                          labels: {
                              font: {
                                  size: 12
                              }
                          }
                      }
                  }
              }
          });

          // Storage by Client Chart
          const storageCtx = document.getElementById('storageByClientChart').getContext('2d');
          new Chart(storageCtx, {
              type: 'bar',
              data: {
                  labels: [
                      // 🤖 LLM: Replace with actual client names
                      '{{CLIENT1_NAME}}' || 'Client 1',
                      '{{CLIENT2_NAME}}' || 'Client 2',
                      '{{CLIENT3_NAME}}' || 'Client 3'
                  ],
                  datasets: [{
                      label: 'Storage Used (GB)',
                      data: [
                          // 🤖 LLM: Replace with actual storage usage data
                          parseInt('{{CLIENT1_TOTAL_STORAGE}}') || 150,
                          parseInt('{{CLIENT2_TOTAL_STORAGE}}') || 230,
                          parseInt('{{CLIENT3_TOTAL_STORAGE}}') || 180
                      ],
                      backgroundColor: '#8b5cf6',
                      borderColor: '#7c3aed',
                      borderWidth: 1
                  }]
              },
              options: {
                  responsive: true,
                  scales: {
                      y: {
                          beginAtZero: true,
                          title: {
                              display: true,
                              text: 'Storage (GB)'
                          }
                      }
                  }
              }
          });

          // Daily Volume Chart
          const volumeCtx = document.getElementById('dailyVolumeChart').getContext('2d');
          new Chart(volumeCtx, {
              type: 'line',
              data: {
                  labels: ['6 days ago', '5 days ago', '4 days ago', '3 days ago', '2 days ago', 'Yesterday', 'Today'],
                  datasets: [{
                      label: 'Backup Volume (GB)',
                      data: [
                          // 🤖 LLM: Replace with actual daily backup volume data
                          45, 52, 48, 61, 55, 58, parseInt('{{TODAY_BACKUP_VOLUME}}') || 62
                      ],
                      borderColor: '#3b82f6',
                      backgroundColor: 'rgba(59, 130, 246, 0.1)',
                      tension: 0.4,
                      fill: true
                  }]
              },
              options: {
                  responsive: true,
                  scales: {
                      y: {
                          beginAtZero: true,
                          title: {
                              display: true,
                              text: 'Volume (GB)'
                          }
                      }
                  }
              }
          });

          // Storage usage charts for devices (example for client1device1)
          const device1StorageCtx = document.getElementById('client1Device1StorageChart').getContext('2d');
          new Chart(device1StorageCtx, {
              type: 'doughnut',
              data: {
                  labels: ['Used', 'Free'],
                  datasets: [{
                      data: [
                          // 🤖 LLM: Replace with actual storage data for this device
                          parseInt('{{CLIENT1_DEVICE1_STORAGE_USED_GB}}') || 75,
                          parseInt('{{CLIENT1_DEVICE1_STORAGE_FREE_GB}}') || 125
                      ],
                      backgroundColor: ['#f59e0b', '#e5e7eb'],
                      borderWidth: 2,
                      borderColor: '#ffffff'
                  }]
              },
              options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                      legend: {
                          position: 'bottom',
                          labels: {
                              font: {
                                  size: 10
                              }
                          }
                      }
                  }
              }
          });
      };
